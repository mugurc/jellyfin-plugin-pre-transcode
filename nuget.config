<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet configuration. `<clear />` ensures the build does not depend on
    whatever sources happen to be configured (or missing) on the machine, so a plain
    `dotnet build` works reproducibly here and in CI.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
